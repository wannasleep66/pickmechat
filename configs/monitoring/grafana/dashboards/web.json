{
  "title": "Pickmechat",
  "uid": "pickmechat",
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "tags": ["pickmechat", "starlette"],
  "schemaVersion": 36,
  "refresh": "10s",
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "HTTP",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Requests per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(starlette_requests_total{app_name=\"pickmechat\"}[$__rate_interval]))",
          "legendFormat": "All"
        },
        {
          "expr": "sum(rate(starlette_requests_total{app_name=\"pickmechat\",status_code=~\"2..\"}[$__rate_interval]))",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(rate(starlette_requests_total{app_name=\"pickmechat\",status_code=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(starlette_requests_total{app_name=\"pickmechat\",status_code=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests in progress",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(starlette_requests_in_progress{app_name=\"pickmechat\"})",
          "legendFormat": "In progress"
        }
      ]
    },
    {
      "id": 4,
      "title": "Error rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(starlette_requests_total{app_name=\"pickmechat\",status_code=~\"[45]..\"}[$__rate_interval])) / sum(rate(starlette_requests_total{app_name=\"pickmechat\"}[$__rate_interval])) * 100",
          "legendFormat": "Error rate"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top endpoints",
      "type": "table",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left" },
          "displayMode": "color-background",
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Requests" },
            "properties": [
              { "id": "custom.width", "value": 100 },
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Errors" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Error rate" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "orange", "value": 5 },
                    { "color": "red", "value": 20 }
                  ]
                }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P50" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.width", "value": 70 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P95" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.width", "value": 70 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "P99" },
            "properties": [
              { "id": "unit", "value": "s" },
              { "id": "custom.width", "value": 70 }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [{ "displayName": "Requests", "desc": true }]
      },
      "transformations": [
        {
          "id": "groupBy",
          "options": {
            "fields": {
              "method": { "aggregations": [], "operation": "groupby" },
              "path": { "aggregations": [], "operation": "groupby" },
              "Requests": { "aggregations": ["sum"], "operation": "aggregate" },
              "Errors": { "aggregations": ["sum"], "operation": "aggregate" },
              "Error rate": {
                "aggregations": ["sum"],
                "operation": "aggregate"
              },
              "P50": { "aggregations": ["mean"], "operation": "aggregate" },
              "P95": { "aggregations": ["mean"], "operation": "aggregate" },
              "P99": { "aggregations": ["mean"], "operation": "aggregate" }
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "sum(rate(starlette_requests_total{app_name=\"pickmechat\"}[$__rate_interval])) by (method, path)",
          "format": "table",
          "instant": true,
          "legendFormat": "Requests"
        },
        {
          "expr": "sum(rate(starlette_requests_total{app_name=\"pickmechat\",status_code=~\"[45]..\"}[$__rate_interval])) by (method, path)",
          "format": "table",
          "instant": true,
          "legendFormat": "Errors"
        },
        {
          "expr": "sum(rate(starlette_requests_total{app_name=\"pickmechat\",status_code=~\"[45]..\"}[$__rate_interval])) by (method, path) / sum(rate(starlette_requests_total{app_name=\"pickmechat\"}[$__rate_interval])) by (method, path) * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "Error rate"
        },
        {
          "expr": "histogram_quantile(0.5, sum(rate(starlette_request_duration_seconds_bucket{app_name=\"pickmechat\"}[$__rate_interval])) by (le, method, path))",
          "format": "table",
          "instant": true,
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(starlette_request_duration_seconds_bucket{app_name=\"pickmechat\"}[$__rate_interval])) by (le, method, path))",
          "format": "table",
          "instant": true,
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(starlette_request_duration_seconds_bucket{app_name=\"pickmechat\"}[$__rate_interval])) by (le, method, path))",
          "format": "table",
          "instant": true,
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 6,
      "title": "Request duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineInterpolation": "smooth",
            "showPoints": "never",
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": ["mean", "max"],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, sum(rate(starlette_request_duration_seconds_bucket{app_name=\"pickmechat\"}[$__rate_interval])) by (le))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.9, sum(rate(starlette_request_duration_seconds_bucket{app_name=\"pickmechat\"}[$__rate_interval])) by (le))",
          "legendFormat": "P90"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(starlette_request_duration_seconds_bucket{app_name=\"pickmechat\"}[$__rate_interval])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(starlette_request_duration_seconds_bucket{app_name=\"pickmechat\"}[$__rate_interval])) by (le))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 7,
      "title": "Request duration heatmap",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "options": {
        "calculate": false,
        "color": { "mode": "scheme", "scheme": "YlOrRd" },
        "yAxis": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "sum(rate(starlette_request_duration_seconds_bucket{app_name=\"pickmechat\"}[$__rate_interval])) by (le)",
          "format": "heatmap",
          "legendFormat": "{{le}}"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 8,
      "panels": [],
